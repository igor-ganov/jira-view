{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jira-view",
  "compatibility_date": "2026-03-23",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/_worker.js/index.js",
  // Astro's Cloudflare adapter emits the worker plus static assets into ./dist.
  "assets": { "directory": "./dist", "binding": "ASSETS" },
  // Server-side session store. Create the namespace once and paste its id:
  //   wrangler kv namespace create SESSION
  "kv_namespaces": [{ "binding": "SESSION", "id": "d615cae820ad4bc3a5bdb21d0c1d9277" }],
  "observability": { "enabled": true }
}
