# Atlassian OAuth 2.0 (3LO) app — create at https://developer.atlassian.com/console/myapps/
# App settings → Authorization → OAuth 2.0 (3LO) → Callback URL must equal JIRA_REDIRECT_URI below.
# App settings → Permissions → add "Jira API" with scopes: read:jira-work read:jira-user

JIRA_CLIENT_ID=your-client-id
JIRA_CLIENT_SECRET=your-client-secret
JIRA_REDIRECT_URI=http://localhost:4321/auth/callback

# Space-separated OAuth scopes. offline_access yields a refresh token.
JIRA_SCOPES=read:jira-work read:jira-user offline_access

# Random 32+ char string used to HMAC-sign the session cookie.
# Generate: bun -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
SESSION_SECRET=change-me-to-a-long-random-string
