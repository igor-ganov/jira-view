---
type Props = { readonly title: string };
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e1116" media="(prefers-color-scheme: dark)" />
    <title>{title}</title>
    {/* Apply the saved theme before paint to avoid a flash. */}
    <script is:inline>
      const saved = localStorage.getItem('theme');
      if (saved === 'light' || saved === 'dark') {
        document.documentElement.dataset.theme = saved;
      }
    </script>
    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #f6f7f9;
        --surface: #ffffff;
        --surface-2: #f1f3f5;
        --border: #e6e8eb;
        --text: #1a1d23;
        --text-muted: #6b7280;
        --accent: #6366f1;
        --accent-contrast: #ffffff;
        --danger: #dc2626;
        --danger-soft: #fef2f2;
        --cat-new-bg: #eef0f2;
        --cat-new-fg: #4b5563;
        --cat-prog-bg: #e0e7ff;
        --cat-prog-fg: #3730a3;
        --cat-done-bg: #dcfce7;
        --cat-done-fg: #166534;
        --radius: 12px;
        --radius-sm: 8px;
        --shadow: 0 1px 2px rgba(16, 24, 40, 0.05), 0 1px 3px rgba(16, 24, 40, 0.08);
        --shadow-lg: 0 10px 30px rgba(16, 24, 40, 0.18);
        --focus: 0 0 0 3px color-mix(in srgb, var(--accent) 40%, transparent);
        --font:
          'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial,
          sans-serif;
      }

      @media (prefers-color-scheme: dark) {
        :root:not([data-theme='light']) {
          --bg: #0e1116;
          --surface: #171b21;
          --surface-2: #1f242c;
          --border: #2a2f37;
          --text: #e6e8eb;
          --text-muted: #98a2b3;
          --accent: #818cf8;
          --accent-contrast: #0e1116;
          --danger: #f87171;
          --danger-soft: #2a1416;
          --cat-new-bg: #262b33;
          --cat-new-fg: #c2c8d0;
          --cat-prog-bg: #1e2a4a;
          --cat-prog-fg: #93c5fd;
          --cat-done-bg: #11301f;
          --cat-done-fg: #86efac;
          --shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
          --shadow-lg: 0 12px 34px rgba(0, 0, 0, 0.55);
        }
      }

      /* Tie native controls (checkbox, dropdown, scrollbar) to the chosen
         theme — otherwise a manual override fights the OS color-scheme and
         e.g. checkboxes render dark on a light card. */
      :root[data-theme='light'] {
        color-scheme: light;
      }
      :root[data-theme='dark'] {
        color-scheme: dark;
        --bg: #0e1116;
        --surface: #171b21;
        --surface-2: #1f242c;
        --border: #2a2f37;
        --text: #e6e8eb;
        --text-muted: #98a2b3;
        --accent: #818cf8;
        --accent-contrast: #0e1116;
        --danger: #f87171;
        --danger-soft: #2a1416;
        --cat-new-bg: #262b33;
        --cat-new-fg: #c2c8d0;
        --cat-prog-bg: #1e2a4a;
        --cat-prog-fg: #93c5fd;
        --cat-done-bg: #11301f;
        --cat-done-fg: #86efac;
        --shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
        --shadow-lg: 0 12px 34px rgba(0, 0, 0, 0.55);
      }

      * {
        box-sizing: border-box;
      }
      html {
        -webkit-text-size-adjust: 100%;
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }
      header.app {
        position: sticky;
        top: 0;
        z-index: 20;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 0.7rem max(1rem, env(safe-area-inset-left)) 0.7rem
          max(1rem, env(safe-area-inset-right));
        background: color-mix(in srgb, var(--bg) 85%, transparent);
        backdrop-filter: saturate(180%) blur(10px);
        border-bottom: 1px solid var(--border);
      }
      header.app .brand {
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: -0.01em;
        color: var(--text);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }
      header.app .brand .dot {
        width: 0.6rem;
        height: 0.6rem;
        border-radius: 999px;
        background: var(--accent);
      }
      main {
        max-width: 760px;
        margin: 0 auto;
        padding: 1.5rem max(1rem, env(safe-area-inset-left)) 4rem
          max(1rem, env(safe-area-inset-right));
      }
      h1 {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 1rem;
      }
      a.button {
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        padding: 0.6rem 1.2rem;
        background: var(--accent);
        color: var(--accent-contrast);
        border-radius: 999px;
        text-decoration: none;
        font-weight: 600;
      }
      a.link {
        color: var(--accent);
        font-size: 0.875rem;
        text-decoration: none;
      }
      a.link:hover {
        text-decoration: underline;
      }
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text);
        cursor: pointer;
        font-size: 1.05rem;
        line-height: 1;
      }
      :focus-visible {
        outline: none;
        box-shadow: var(--focus);
        border-radius: 6px;
      }
    </style>
  </head>
  <body>
    <header class="app">
      <a class="brand" href="/"><span class="dot"></span> Jira View</a>
      <button
        class="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        title="Toggle dark mode"
        data-theme-toggle>🌗</button
      >
    </header>
    <main><slot /></main>

    <script is:inline>
      const root = document.documentElement;
      document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
        const current =
          root.dataset.theme ||
          (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        const next = current === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>
