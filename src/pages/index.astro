---
import { SESSION_TOKENS_KEY } from '@/features/auth/session';
import Base from '@/layouts/base.astro';

const tokens = await Astro.session?.get(SESSION_TOKENS_KEY);
const isAuthenticated = tokens !== undefined;
---

<Base title="Jira View">
  <h1>Jira View</h1>
  <p>A calm, unbreakable alternative to the Jira backlog/board UI.</p>

  {
    isAuthenticated ? (
      <Fragment>
        <p>
          <a class="link" href="/auth/logout">
            Log out
          </a>
        </p>
        <jira-projects></jira-projects>
        <script>
          import '@/components/jira-projects';
        </script>
      </Fragment>
    ) : (
      <a class="button" href="/auth/login">
        Connect Jira
      </a>
    )
  }
</Base>
